# =============================================
# BrandPilot AI/LangGraph 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일로 만들고
# 실제 키 값을 입력하세요.
# cp .env.example .env
# =============================================

# OpenAI API Key (필수)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key (선택)
# 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# DB 활성화 여부 (로컬 개발 시 false 권장)
ENABLE_DB=false

# PostgreSQL DB 연결 설정 (ENABLE_DB=true 일 때만 필요)
# DB 연결은 database/connection.py에서 사용됩니다
DB_HOST=localhost
DB_PORT=5432
DB_NAME=brand_consulting
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# 디버그 모드 (SQL 로그 출력 여부, 개발 시 true)
LANGGRAPH_DEBUG=false

# Cloudinary 이미지 호스팅 설정 (이미지 저장 시 필요)
# 발급: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
