# =============================================
# BrandPilot branding-frontend 환경변수 설정 예시
# 이 파일을 복사해서 .env 파일로 만들고
# 실제 값을 입력하세요.
# cp .env.example .env
# =============================================

# 백엔드 API 서버 URL (예: http://localhost:8080)
VITE_API_BASE_URL=http://your-backend-server-url

# AI API 서버 URL (Nginx 프록시 경로, 변경 불필요)
VITE_AI_API_BASE_URL=/ai-api
